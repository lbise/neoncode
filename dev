#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

usage() {
  cat <<'EOF'
NeonCode developer commands

Usage:
  ./dev <command>

Daily commands:
  ./dev app          Publish/start Electron + xterm.js app
  ./dev publish      Publish Electron app to %USERPROFILE%\neoncode-electron
  ./dev hub          Run the Rust NeonCode hub
  ./dev check        Run strict TypeScript + Rust tests/fmt/check/clippy
  ./dev soak [secs]  Repeat real PTY metadata/reconnect tests (default: 300)

Electron app commands:
  ./dev electron-publish              Publish Electron app
  ./dev electron                      Start already-published Electron app
  ./dev electron-stop                 Force-stop only published NeonCode Electron processes
  ./dev electron-install  Install Electron npm dependencies in source app
  ./dev electron-audit    Audit the locked Electron app dependencies
  ./dev electron-test     Run hidden-window Playwright functional tests

Utility commands:
  ./dev reset-token  Rotate the local hub capability token
  ./dev status       Show git status and important output paths
  ./dev help         Show this help

Typical loop:
  Terminal 1: ./dev hub
  Terminal 2: ./dev app

EOF
}

token_file() {
  printf '%s/neoncode/hub-token\n' "${XDG_STATE_HOME:-$HOME/.local/state}"
}

ensure_hub_token() {
  if [[ -n "${NEONCODE_HUB_TOKEN:-}" ]]; then
    if [[ ! "$NEONCODE_HUB_TOKEN" =~ ^[0-9a-fA-F]{64}$ ]]; then
      echo "NEONCODE_HUB_TOKEN must contain exactly 64 hexadecimal characters" >&2
      exit 2
    fi
    export NEONCODE_HUB_TOKEN
    return
  fi

  local path directory token lock_fd temporary
  path="$(token_file)"
  directory="$(dirname "$path")"
  umask 077
  mkdir -p "$directory"
  if [[ -L "$directory" || ! -d "$directory" || "$(stat -c '%u' "$directory")" != "$(id -u)" ]]; then
    echo "Hub token directory must be a real directory owned by the current user: $directory" >&2
    exit 2
  fi
  chmod 700 "$directory"

  exec {lock_fd}>"$directory/.hub-token.lock"
  chmod 600 "$directory/.hub-token.lock"
  flock "$lock_fd"

  if [[ -L "$path" || ( -e "$path" && ! -f "$path" ) ]]; then
    echo "Hub token path must be a regular file, not a symlink: $path" >&2
    exit 2
  fi
  if [[ -f "$path" && "$(stat -c '%u' "$path")" != "$(id -u)" ]]; then
    echo "Hub token file must be owned by the current user: $path" >&2
    exit 2
  fi

  token=""
  if [[ -f "$path" ]]; then
    token="$(tr -d '\r\n' <"$path")"
  fi
  if [[ ! "$token" =~ ^[0-9a-fA-F]{64}$ ]]; then
    token="$(od -An -N32 -tx1 /dev/urandom | tr -d ' \n')"
    temporary="$(mktemp "$directory/.hub-token.tmp.XXXXXX")"
    if ! printf '%s\n' "$token" >"$temporary"; then
      rm -f "$temporary"
      exit 1
    fi
    chmod 600 "$temporary"
    mv -fT "$temporary" "$path"
  fi
  chmod 600 "$path"
  flock -u "$lock_fd"
  exec {lock_fd}>&-
  export NEONCODE_HUB_TOKEN="$token"
}

ps_file() {
  local script="$1"
  local bridge_env="${WSLENV:-}"
  shift
  if [[ -n "${NEONCODE_HUB_TOKEN:-}" && ":$bridge_env:" != *":NEONCODE_HUB_TOKEN:"* ]]; then
    bridge_env="${bridge_env:+$bridge_env:}NEONCODE_HUB_TOKEN"
  fi
  WSLENV="$bridge_env" powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$script" "$@"
}

publish_electron_app() {
  ps_file 'scripts\electron-app.ps1' -Command publish "$@"
}

run_electron_app() {
  ensure_hub_token
  ps_file 'scripts\electron-app.ps1' -Command start "$@"
}

command="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$command" in
  help|-h|--help)
    usage
    ;;

  app)
    publish_electron_app "$@"
    run_electron_app
    ;;

  publish|electron-publish)
    publish_electron_app "$@"
    ;;

  electron)
    run_electron_app "$@"
    ;;

  electron-stop)
    ps_file 'scripts\electron-app.ps1' -Command stop
    ;;

  electron-install)
    ps_file 'scripts\electron-app.ps1' -Command install
    ;;

  electron-audit)
    (cd frontends/electron && npm audit --package-lock-only)
    ;;

  hub)
    ensure_hub_token
    cargo run -p neoncode-hub
    ;;

  soak)
    duration="${1:-300}"
    if [[ ! "$duration" =~ ^[0-9]+$ ]] || (( duration < 1 || duration > 86400 )); then
      echo "soak duration must be an integer between 1 and 86400 seconds" >&2
      exit 2
    fi
    started=$SECONDS
    iterations=0
    while (( SECONDS - started < duration )); do
      cargo test -p neoncode-hub --test session_lifecycle \
        persistent_session_survives_repeated_checkpoint_reconnects -- --exact
      cargo test -p neoncode-hub --test session_lifecycle \
        session_metadata_tracks_persistence_and_attachments -- --exact
      iterations=$((iterations + 1))
      echo "soak iteration $iterations complete ($((SECONDS - started))s/${duration}s)"
    done
    echo "soak passed: $iterations iterations in $((SECONDS - started))s"
    ;;

  check)
    bash -n dev
    while IFS= read -r -d '' js_file; do
      node --check "$js_file"
    done < <(find frontends/electron \
      -path 'frontends/electron/node_modules' -prune -o \
      -name '*.js' -print0)
    npm --prefix frontends/electron run check
    cargo fmt --check
    cargo check
    cargo test
    cargo clippy --all-targets -- -D warnings
    ;;

  electron-test)
    ensure_hub_token
    ps_file 'scripts\electron-test.ps1' "$@"
    ;;

  reset-token)
    if [[ -n "${NEONCODE_HUB_TOKEN:-}" ]]; then
      echo "Unset the externally supplied NEONCODE_HUB_TOKEN before rotating the managed token." >&2
      exit 2
    fi
    path="$(token_file)"
    rm -f "$path"
    ensure_hub_token
    echo "Rotated local hub token. Restart the hub and Electron app."
    ;;

  status)
    git status --short --branch
    cat <<'EOF'

Important paths:
  Electron app: %USERPROFILE%\neoncode-electron
  App logs:     %TEMP%\NeonCode\electron-app-main.log

Useful commands:
  ./dev hub
  ./dev app
  ./dev check
EOF
    ;;

  *)
    echo "Unknown command: $command" >&2
    echo >&2
    usage >&2
    exit 2
    ;;
esac
