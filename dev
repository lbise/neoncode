#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

usage() {
  cat <<'EOF'
NeonCode developer commands

Usage:
  ./dev <command>

Daily commands:
  ./dev app          Stop running Windows app, publish frontend, start published app
  ./dev publish      Stop running Windows app, then publish frontend
  ./dev hub          Run the Rust NeonCode hub
  ./dev check        Run frontend build + Rust fmt/check/clippy

Windows Terminal dependency commands:
  ./dev wt-bootstrap Bootstrap pinned Windows Terminal dependency
  ./dev wt-build     Bootstrap/build Microsoft.Terminal.Control.dll
  ./dev full         Build Windows Terminal control, then publish Windows app

Spike commands:
  ./dev electron-spike-publish Publish Electron spike to %USERPROFILE%\neoncode-electron-spike
  ./dev electron-spike         Start the published Electron spike
  ./dev electron-spike-install Install Electron spike npm dependencies in-place
  ./dev electron-spike-native  Build the Electron spike native WPF terminal host

Utility commands:
  ./dev run-app      Start the already-published Windows app
  ./dev stop-app     Stop running NeonCode.Windows processes
  ./dev status       Show git status and important output paths
  ./dev help         Show this help

Typical loop:
  Terminal 1: ./dev hub
  Terminal 2: ./dev app

EOF
}

ps_file() {
  local script="$1"
  shift
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$script" "$@"
}

ps_command() {
  powershell.exe -NoProfile -Command "$1"
}

stop_app() {
  ps_command '$p = Get-Process NeonCode.Windows -ErrorAction SilentlyContinue; if ($p) { $p | Stop-Process -Force }; exit 0'
}

publish_app() {
  ps_file 'scripts\publish-windows-frontend.ps1' "$@"
}

run_app() {
  ps_command 'Start-Process "$env:USERPROFILE\neoncode-publish\NeonCode.Windows.exe"'
}

command="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$command" in
  help|-h|--help)
    usage
    ;;

  app)
    stop_app
    publish_app "$@"
    run_app
    ;;

  publish)
    stop_app
    publish_app "$@"
    ;;

  run-app)
    run_app
    ;;

  stop-app)
    stop_app
    ;;

  hub)
    cargo run -p neoncode-hub
    ;;

  check)
    ps_command 'dotnet build frontends\windows\NeonCode.Windows\NeonCode.Windows.csproj -v:minimal'
    cargo fmt --check
    cargo check
    cargo clippy --all-targets -- -D warnings
    ;;

  wt-bootstrap)
    ps_file 'scripts\bootstrap-windows-terminal.ps1' "$@"
    ;;

  wt-build)
    ps_file 'scripts\build-windows-terminal-control.ps1' "$@"
    ;;

  full)
    ps_file 'scripts\build-windows-terminal-control.ps1'
    publish_app
    ;;

  electron-spike-publish)
    ps_file 'scripts\electron-spike.ps1' -Command publish "$@"
    ;;

  electron-spike-install)
    ps_file 'scripts\electron-spike.ps1' -Command install
    ;;

  electron-spike-native)
    ps_file 'scripts\electron-spike.ps1' -Command build-native
    ;;

  electron-spike)
    ps_file 'scripts\electron-spike.ps1' -Command start
    ;;

  status)
    git status --short --branch
    cat <<'EOF'

Important paths:
  Windows publish: %USERPROFILE%\neoncode-publish
  App config:      %APPDATA%\NeonCode\config.json
  WT checkout:     %USERPROFILE%\gitrepo\microsoft-terminal
  vcpkg:           %USERPROFILE%\gitrepo\vcpkg

Useful commands:
  ./dev hub
  ./dev app
  ./dev check
EOF
    ;;

  *)
    echo "Unknown command: $command" >&2
    echo >&2
    usage >&2
    exit 2
    ;;
esac
