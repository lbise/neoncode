#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

usage() {
  cat <<'EOF'
NeonCode developer commands

Usage:
  ./dev <command>

Daily commands:
  ./dev app          Publish/start Electron + xterm.js app
  ./dev publish      Publish Electron app to %USERPROFILE%\neoncode-electron
  ./dev hub          Run the Rust NeonCode hub
  ./dev check        Run Electron JS checks + Rust fmt/check/clippy

Electron app commands:
  ./dev electron-publish              Publish Electron app
  ./dev electron                      Start already-published Electron app
  ./dev electron-install              Install Electron npm dependencies in source app
  ./dev electron-xterm-smoke          Validate running app hub input/output
  ./dev electron-xterm-resize-smoke   Validate xterm resize propagation with stty size
  ./dev electron-xterm-playwright-smoke Validate app DOM/state/input with Playwright
  ./dev electron-xterm-behavior-smoke Validate basic command/Ctrl+C/tool availability

Utility commands:
  ./dev status       Show git status and important output paths
  ./dev help         Show this help

Typical loop:
  Terminal 1: ./dev hub
  Terminal 2: ./dev app

EOF
}

ps_file() {
  local script="$1"
  shift
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$script" "$@"
}

publish_electron_app() {
  ps_file 'scripts\electron-app.ps1' -Command publish "$@"
}

run_electron_app() {
  if [[ $# -gt 0 ]]; then
    ps_file 'scripts\electron-app.ps1' -Command start "$@"
  else
    ps_file 'scripts\electron-app.ps1' -Command start -TerminalCount 2
  fi
}

command="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$command" in
  help|-h|--help)
    usage
    ;;

  app)
    publish_electron_app "$@"
    run_electron_app
    ;;

  publish|electron-publish)
    publish_electron_app "$@"
    ;;

  electron)
    run_electron_app "$@"
    ;;

  electron-install)
    ps_file 'scripts\electron-app.ps1' -Command install
    ;;

  hub)
    cargo run -p neoncode-hub
    ;;

  check)
    bash -n dev
    while IFS= read -r -d '' js_file; do
      node --check "$js_file"
    done < <(find frontends/electron \
      -path 'frontends/electron/node_modules' -prune -o \
      -name '*.js' -print0)
    cargo fmt --check
    cargo check
    cargo test
    cargo clippy --all-targets -- -D warnings
    ;;

  electron-xterm-smoke)
    ps_file 'scripts\electron-xterm-smoke.ps1' "$@"
    ;;

  electron-xterm-resize-smoke)
    ps_file 'scripts\electron-xterm-resize-smoke.ps1' "$@"
    ;;

  electron-xterm-playwright-smoke)
    ps_file 'scripts\electron-xterm-playwright-smoke.ps1' "$@"
    ;;

  electron-xterm-behavior-smoke)
    ps_file 'scripts\electron-xterm-behavior-smoke.ps1' "$@"
    ;;

  # Backward-compatible aliases for recent docs/scripts while the app rename settles.
  electron-xterm-publish)
    publish_electron_app "$@"
    ;;

  electron-xterm)
    run_electron_app "$@"
    ;;

  electron-xterm-install)
    ps_file 'scripts\electron-app.ps1' -Command install
    ;;

  status)
    git status --short --branch
    cat <<'EOF'

Important paths:
  Electron app: %USERPROFILE%\neoncode-electron
  App logs:     %TEMP%\NeonCode\electron-app-main.log

Useful commands:
  ./dev hub
  ./dev app
  ./dev check
EOF
    ;;

  *)
    echo "Unknown command: $command" >&2
    echo >&2
    usage >&2
    exit 2
    ;;
esac
