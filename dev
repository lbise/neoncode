#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

if ! command -v cargo >/dev/null 2>&1 && [[ -f "$HOME/.cargo/env" ]]; then
  # rustup installs cargo here, but non-interactive shells may not source it.
  # shellcheck source=/dev/null
  . "$HOME/.cargo/env"
fi

usage() {
  cat <<'EOF'
NeonCode developer commands

Usage:
  ./dev <command>

Daily commands:
  ./dev app          Build/start Electron + xterm.js app
  ./dev publish      Build Electron artifacts (and publish to Windows when WSL bridge exists)
  ./dev hub          Run the Rust NeonCode hub
  ./dev check        Run strict TypeScript + Rust tests/fmt/check/clippy
  ./dev soak [secs]  Repeat real PTY metadata/reconnect tests (default: 300)
  ./dev cli <args>   Run authenticated NeonCode CLI (status/sessions/notify)

Electron app commands:
  ./dev electron-publish              Build/publish Electron app
  ./dev electron                      Start Electron app
  ./dev electron-stop                 Force-stop NeonCode Electron processes when supported
  ./dev electron-bootstrap     Explicitly install/verify the stable Windows Electron runtime
  ./dev electron-runtime-status Show runtime hash/marker/signature without execution
  ./dev electron-runtime-probe  Optional direct high-integrity execution diagnostic
  ./dev electron-install       Alias for electron-bootstrap
  ./dev electron-audit         Audit the locked Electron app dependencies
  ./dev electron-test     Run headless-safe Electron functional tests on Linux SSH/Xvfb
  ./dev electron-test-headless Run headless-safe Electron tests explicitly
  ./dev electron-test-gui Run full GUI Electron tests including tmux/nvim mouse checks
  ./dev electron-sandbox-fix Configure Electron's Linux chrome-sandbox helper
  ./dev package-linux     Build native Linux alpha AppImage/tar.gz artifacts

Release commands:
  ./dev release-alpha      Build, package, sign (optional), and verify Windows alpha artifacts
  ./dev package-alpha      Package alpha artifacts from existing release build outputs
  ./dev verify-release     Verify alpha hashes, signatures, and Defender scan when available
  ./dev alpha-run-portable Verify/copy/unblock/launch the portable alpha for dogfooding
  ./dev clean-vm-check    Print/run clean-VM release verification checklist

Utility commands:
  ./dev reset-token  Rotate the local hub capability token
  ./dev status       Show git status and important output paths
  ./dev help         Show this help

Typical loop:
  Terminal 1: ./dev hub
  Terminal 2: ./dev app

EOF
}

token_file() {
  printf '%s/neoncode/hub-token\n' "${XDG_STATE_HOME:-$HOME/.local/state}"
}

ensure_hub_token() {
  if [[ -n "${NEONCODE_HUB_TOKEN:-}" ]]; then
    if [[ ! "$NEONCODE_HUB_TOKEN" =~ ^[0-9a-fA-F]{64}$ ]]; then
      echo "NEONCODE_HUB_TOKEN must contain exactly 64 hexadecimal characters" >&2
      exit 2
    fi
    export NEONCODE_HUB_TOKEN
    return
  fi

  local path directory token lock_fd temporary
  path="$(token_file)"
  directory="$(dirname "$path")"
  umask 077
  mkdir -p "$directory"
  if [[ -L "$directory" || ! -d "$directory" || "$(stat -c '%u' "$directory")" != "$(id -u)" ]]; then
    echo "Hub token directory must be a real directory owned by the current user: $directory" >&2
    exit 2
  fi
  chmod 700 "$directory"

  exec {lock_fd}>"$directory/.hub-token.lock"
  chmod 600 "$directory/.hub-token.lock"
  flock "$lock_fd"

  if [[ -L "$path" || ( -e "$path" && ! -f "$path" ) ]]; then
    echo "Hub token path must be a regular file, not a symlink: $path" >&2
    exit 2
  fi
  if [[ -f "$path" && "$(stat -c '%u' "$path")" != "$(id -u)" ]]; then
    echo "Hub token file must be owned by the current user: $path" >&2
    exit 2
  fi

  token=""
  if [[ -f "$path" ]]; then
    token="$(tr -d '\r\n' <"$path")"
  fi
  if [[ ! "$token" =~ ^[0-9a-fA-F]{64}$ ]]; then
    token="$(od -An -N32 -tx1 /dev/urandom | tr -d ' \n')"
    temporary="$(mktemp "$directory/.hub-token.tmp.XXXXXX")"
    if ! printf '%s\n' "$token" >"$temporary"; then
      rm -f "$temporary"
      exit 1
    fi
    chmod 600 "$temporary"
    mv -fT "$temporary" "$path"
  fi
  chmod 600 "$path"
  flock -u "$lock_fd"
  exec {lock_fd}>&-
  export NEONCODE_HUB_TOKEN="$token"
}

windows_bridge_available() {
  command -v powershell.exe >/dev/null 2>&1
}

ps_file() {
  local script="$1"
  local bridge_env="${WSLENV:-}"
  shift
  if ! windows_bridge_available; then
    echo "Windows bridge is unavailable on this host; use the native Linux Electron commands." >&2
    exit 2
  fi
  if [[ -n "${NEONCODE_HUB_TOKEN:-}" && ":$bridge_env:" != *":NEONCODE_HUB_TOKEN:"* ]]; then
    bridge_env="${bridge_env:+$bridge_env:}NEONCODE_HUB_TOKEN"
  fi
  if [[ -n "${NEONCODE_WSL_NODE_BIN:-}" && ":$bridge_env:" != *":NEONCODE_WSL_NODE_BIN:"* ]]; then
    bridge_env="${bridge_env:+$bridge_env:}NEONCODE_WSL_NODE_BIN"
  fi
  WSLENV="$bridge_env" powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$script" "$@"
}

publish_electron_app() {
  npm --prefix frontends/electron run build
  if windows_bridge_available; then
    ps_file 'scripts\electron-app.ps1' -Command publish "$@"
  else
    echo "Built native Linux Electron app artifacts under frontends/electron/dist."
  fi
}

electron_sandbox_path() {
  printf '%s/frontends/electron/node_modules/electron/dist/chrome-sandbox\n' "$ROOT_DIR"
}

check_linux_electron_sandbox() {
  if windows_bridge_available || [[ "$(uname -s)" != "Linux" ]]; then
    return
  fi
  local sandbox
  sandbox="$(electron_sandbox_path)"
  if [[ ! -e "$sandbox" ]]; then
    return
  fi
  if [[ "$(stat -c '%u:%a' "$sandbox")" == "0:4755" ]]; then
    return
  fi
  cat >&2 <<EOF
Electron's Linux sandbox helper is not configured correctly:
  $sandbox

Run this once after npm ci refreshes Electron:
  sudo chown root:root "$sandbox"
  sudo chmod 4755 "$sandbox"

EOF
  exit 2
}

fix_linux_electron_sandbox() {
  local sandbox
  sandbox="$(electron_sandbox_path)"
  if [[ ! -e "$sandbox" ]]; then
    echo "Electron sandbox helper is missing. Run: npm --prefix frontends/electron ci" >&2
    exit 2
  fi
  sudo chown root:root "$sandbox"
  sudo chmod 4755 "$sandbox"
  echo "Configured Electron sandbox helper: $sandbox"
}

run_electron_app() {
  ensure_hub_token
  if windows_bridge_available; then
    ps_file 'scripts\electron-app.ps1' -Command status
    ps_file 'scripts\electron-app.ps1' -Command start "$@"
  else
    check_linux_electron_sandbox
    (cd frontends/electron && npm start -- "$@")
  fi
}

run_native_electron_test() {
  local suite="$1"
  shift
  ensure_hub_token
  npm --prefix frontends/electron run build
  check_linux_electron_sandbox
  if [[ "$suite" != "headless" && "$suite" != "gui" ]]; then
    echo "Electron test suite must be 'headless' or 'gui'" >&2
    exit 2
  fi
  if [[ -z "${DISPLAY:-}" && -z "${WAYLAND_DISPLAY:-}" ]]; then
    if command -v xvfb-run >/dev/null 2>&1; then
      (cd frontends/electron && NEONCODE_ELECTRON_TEST_SUITE="$suite" xvfb-run -a --server-args='-screen 0 1600x1200x24' npm test -- "$@")
    else
      echo "No DISPLAY/WAYLAND_DISPLAY detected. Install xvfb and retry, or run from a graphical session." >&2
      exit 2
    fi
  else
    (cd frontends/electron && NEONCODE_ELECTRON_TEST_SUITE="$suite" npm test -- "$@")
  fi
}

build_linux_package() {
  cargo build -p neoncode-hub --release
  mkdir -p frontends/electron/resources/hub/linux-x64
  cp target/release/neoncode-hub frontends/electron/resources/hub/linux-x64/neoncode-hub
  chmod 700 frontends/electron/resources/hub/linux-x64/neoncode-hub
  npm --prefix frontends/electron run build
  npm --prefix frontends/electron run package:linux
}

command="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$command" in
  help|-h|--help)
    usage
    ;;

  app)
    publish_electron_app "$@"
    run_electron_app
    ;;

  publish|electron-publish)
    publish_electron_app "$@"
    ;;

  electron)
    run_electron_app "$@"
    ;;

  electron-stop)
    if windows_bridge_available; then
      ps_file 'scripts\electron-app.ps1' -Command stop
    else
      pkill -f 'frontends/electron/node_modules/electron/dist/electron' 2>/dev/null || true
    fi
    ;;

  electron-bootstrap|electron-install)
    ps_file 'scripts\electron-app.ps1' -Command bootstrap
    ;;

  electron-runtime-status)
    ps_file 'scripts\electron-app.ps1' -Command status
    ;;

  electron-runtime-probe)
    ps_file 'scripts\electron-app.ps1' -Command probe
    ;;

  electron-audit)
    (cd frontends/electron && npm audit --package-lock-only)
    ;;

  electron-sandbox-fix)
    fix_linux_electron_sandbox
    ;;

  package-linux)
    build_linux_package "$@"
    ;;

  hub)
    ensure_hub_token
    cargo run -p neoncode-hub
    ;;

  cli)
    ensure_hub_token
    cargo run -q -p neoncode-hub --bin neoncode -- "$@"
    ;;

  soak)
    duration="${1:-300}"
    if [[ ! "$duration" =~ ^[0-9]+$ ]] || (( duration < 1 || duration > 86400 )); then
      echo "soak duration must be an integer between 1 and 86400 seconds" >&2
      exit 2
    fi
    started=$SECONDS
    iterations=0
    while (( SECONDS - started < duration )); do
      cargo test -p neoncode-hub --test session_lifecycle \
        persistent_session_survives_repeated_checkpoint_reconnects -- --exact
      cargo test -p neoncode-hub --test session_lifecycle \
        session_metadata_tracks_persistence_and_attachments -- --exact
      cargo test -p neoncode-hub --test session_lifecycle \
        runtime_git_tracks_branch_dirty_and_detached_state -- --exact
      iterations=$((iterations + 1))
      echo "soak iteration $iterations complete ($((SECONDS - started))s/${duration}s)"
    done
    echo "soak passed: $iterations iterations in $((SECONDS - started))s"
    ;;

  check)
    bash -n dev
    while IFS= read -r -d '' js_file; do
      node --check "$js_file"
    done < <(find frontends/electron \
      -path 'frontends/electron/node_modules' -prune -o \
      -name '*.js' -print0)
    npm --prefix frontends/electron run check
    cargo fmt --check
    cargo check
    cargo test
    cargo clippy --all-targets -- -D warnings
    ;;

  electron-test|electron-test-headless)
    if windows_bridge_available; then
      ensure_hub_token
      ps_file 'scripts\electron-app.ps1' -Command status
      ps_file 'scripts\electron-test.ps1' "$@"
    else
      run_native_electron_test headless "$@"
    fi
    ;;

  electron-test-gui)
    if windows_bridge_available; then
      ensure_hub_token
      ps_file 'scripts\electron-app.ps1' -Command status
      ps_file 'scripts\electron-test.ps1' "$@"
    else
      run_native_electron_test gui "$@"
    fi
    ;;

  release-alpha)
    NEONCODE_WSL_NODE_BIN="$(command -v node || true)" ps_file 'scripts\release-windows.ps1' -WslRepoPath "$ROOT_DIR" "$@"
    ;;

  package-alpha)
    NEONCODE_WSL_NODE_BIN="$(command -v node || true)" ps_file 'scripts\release-windows.ps1' -WslRepoPath "$ROOT_DIR" -SkipRustBuild -SkipElectronBuild "$@"
    ;;

  verify-release)
    ps_file 'scripts\verify-release.ps1' "$@"
    ;;

  alpha-run-portable)
    NEONCODE_WSL_NODE_BIN="$(command -v node || true)" ps_file 'scripts\alpha-run-portable.ps1' -WslRepoPath "$ROOT_DIR" "$@"
    ;;

  clean-vm-check)
    ps_file 'scripts\check-clean-vm-release.ps1' "$@"
    ;;

  reset-token)
    if [[ -n "${NEONCODE_HUB_TOKEN:-}" ]]; then
      echo "Unset the externally supplied NEONCODE_HUB_TOKEN before rotating the managed token." >&2
      exit 2
    fi
    path="$(token_file)"
    rm -f "$path"
    ensure_hub_token
    echo "Rotated local hub token. Restart the hub and Electron app."
    ;;

  status)
    git status --short --branch
    cat <<'EOF'

Important paths:
  Electron app: %USERPROFILE%\neoncode-electron
  App logs:     %TEMP%\NeonCode\electron-app-main.log

Useful commands:
  ./dev hub
  ./dev app
  ./dev check
  ./dev release-alpha
  ./dev verify-release
  ./dev alpha-run-portable
  ./dev clean-vm-check

Release output:
  Windows alpha: release\windows-alpha
  Linux alpha:   release/linux-alpha
EOF
    ;;

  *)
    echo "Unknown command: $command" >&2
    echo >&2
    usage >&2
    exit 2
    ;;
esac
