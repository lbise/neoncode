#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

usage() {
  cat <<'EOF'
NeonCode developer commands

Usage:
  ./dev <command>

Daily commands:
  ./dev app          Publish/start Electron app with direct HwndTerminal coordinator
  ./dev publish      Publish Electron app to %USERPROFILE%\neoncode-electron-spike
  ./dev hub          Run the Rust NeonCode hub
  ./dev check        Run Electron/WPF frontend checks + Rust fmt/check/clippy

Windows Terminal dependency commands:
  ./dev wt-bootstrap Bootstrap pinned Windows Terminal dependency
  ./dev wt-build     Bootstrap/build Microsoft.Terminal.Control.dll
  ./dev full         Build Windows Terminal control, then publish Electron app

WPF reference app commands:
  ./dev wpf-app      Stop running WPF reference app, publish it, start it
  ./dev wpf-publish  Stop running WPF reference app, then publish it
  ./dev wpf-run      Start the already-published WPF reference app
  ./dev wpf-stop     Stop running NeonCode.Windows processes

Electron/direct-native commands:
  ./dev electron-spike-publish Publish Electron app/spike to %USERPROFILE%\neoncode-electron-spike
  ./dev electron-spike         Start Electron with direct HwndTerminal coordinator
  ./dev electron-spike-wpf     Start Electron with the WPF terminal host fallback
  ./dev electron-spike-install Install Electron npm dependencies in-place
  ./dev electron-spike-native  Build the Electron native WPF host and direct native coordinator
  ./dev electron-spike-coordinator Build only the direct native HwndTerminal coordinator
  ./dev electron-spike-focus-test Stress an already-running Electron window
  ./dev electron-spike-direct-hub-smoke Validate direct coordinator hub input/output

Electron/xterm.js spike commands:
  ./dev electron-xterm-publish Publish Electron xterm.js spike
  ./dev electron-xterm         Start published Electron xterm.js spike
  ./dev electron-xterm-install Install Electron xterm.js spike npm dependencies in-place

Utility commands:
  ./dev status       Show git status and important output paths
  ./dev help         Show this help

Typical loop:
  Terminal 1: ./dev hub
  Terminal 2: ./dev app

EOF
}

ps_file() {
  local script="$1"
  shift
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$script" "$@"
}

ps_command() {
  powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "$1"
}

stop_wpf_app() {
  ps_command '$p = Get-Process NeonCode.Windows -ErrorAction SilentlyContinue; if ($p) { $p | Stop-Process -Force }; exit 0'
}

publish_wpf_app() {
  ps_file 'scripts\publish-windows-frontend.ps1' "$@"
}

run_wpf_app() {
  ps_command 'Start-Process "$env:USERPROFILE\neoncode-publish\NeonCode.Windows.exe"'
}

publish_electron_app() {
  ps_file 'scripts\electron-spike.ps1' -Command publish "$@"
}

run_electron_app() {
  ps_file 'scripts\electron-spike.ps1' -Command start -HostKind coordinator -TerminalCount 2
}

run_electron_wpf_app() {
  ps_file 'scripts\electron-spike.ps1' -Command start -HostKind wpf -TerminalCount 2
}

command="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$command" in
  help|-h|--help)
    usage
    ;;

  app)
    publish_electron_app "$@"
    run_electron_app
    ;;

  publish)
    publish_electron_app "$@"
    ;;

  hub)
    cargo run -p neoncode-hub
    ;;

  check)
    node --check spikes/electron-native-terminal/electron/main.js
    node --check spikes/electron-xterm/main.js
    node --check spikes/electron-xterm/renderer.js
    ps_command 'dotnet build spikes\electron-native-terminal\native\NeonCode.ElectronTerminalHost\NeonCode.ElectronTerminalHost.csproj -v:minimal'
    ps_command 'dotnet build frontends\windows\NeonCode.Windows\NeonCode.Windows.csproj -v:minimal'
    cargo fmt --check
    cargo check
    cargo clippy --all-targets -- -D warnings
    ;;

  wt-bootstrap)
    ps_file 'scripts\bootstrap-windows-terminal.ps1' "$@"
    ;;

  wt-build)
    ps_file 'scripts\build-windows-terminal-control.ps1' "$@"
    ;;

  full)
    ps_file 'scripts\build-windows-terminal-control.ps1'
    publish_electron_app
    ;;

  wpf-app)
    stop_wpf_app
    publish_wpf_app "$@"
    run_wpf_app
    ;;

  wpf-publish)
    stop_wpf_app
    publish_wpf_app "$@"
    ;;

  wpf-run)
    run_wpf_app
    ;;

  wpf-stop)
    stop_wpf_app
    ;;

  electron-spike-publish)
    publish_electron_app "$@"
    ;;

  electron-spike-install)
    ps_file 'scripts\electron-spike.ps1' -Command install
    ;;

  electron-spike-native)
    ps_file 'scripts\electron-spike.ps1' -Command build-native
    ;;

  electron-spike-coordinator)
    ps_file 'scripts\electron-spike.ps1' -Command build-coordinator
    ;;

  electron-spike-focus-test)
    ps_file 'scripts\electron-spike-focus-test.ps1' "$@"
    ;;

  electron-spike-direct-hub-smoke)
    ps_file 'scripts\electron-spike-direct-hub-smoke.ps1' "$@"
    ;;

  electron-xterm-publish)
    ps_file 'scripts\electron-xterm-spike.ps1' -Command publish "$@"
    ;;

  electron-xterm-install)
    ps_file 'scripts\electron-xterm-spike.ps1' -Command install
    ;;

  electron-xterm)
    ps_file 'scripts\electron-xterm-spike.ps1' -Command start "$@"
    ;;

  electron-spike)
    run_electron_app
    ;;

  electron-spike-wpf)
    run_electron_wpf_app
    ;;

  electron-spike-direct)
    run_electron_app
    ;;

  status)
    git status --short --branch
    cat <<'EOF'

Important paths:
  Electron app:    %USERPROFILE%\neoncode-electron-spike
  WPF reference:   %USERPROFILE%\neoncode-publish
  App config:      %APPDATA%\NeonCode\config.json
  WT checkout:     %USERPROFILE%\gitrepo\microsoft-terminal
  vcpkg:           %USERPROFILE%\gitrepo\vcpkg

Useful commands:
  ./dev hub
  ./dev app
  ./dev wpf-app
  ./dev check
EOF
    ;;

  *)
    echo "Unknown command: $command" >&2
    echo >&2
    usage >&2
    exit 2
    ;;
esac
