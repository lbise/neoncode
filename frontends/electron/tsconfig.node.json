{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "lib": ["ES2022"],
    "types": ["node"],
    "allowJs": true,
    "checkJs": false
  },
  "include": [
    "main.js",
    "preload.js",
    "config-store.js",
    "token-loader.js",
    "shared/**/*.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
